<Window x:Class="TradingCheckBot.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="코인선물 상하방 전략 체크봇" Height="820" Width="1180"
        MinHeight="640" MinWidth="980"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None" AllowsTransparency="True" ResizeMode="CanResize"
        Background="Transparent" Icon="app.ico"
        FontFamily="Segoe UI, Malgun Gothic">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="40" ResizeBorderThickness="6" GlassFrameThickness="0" CornerRadius="0"/>
    </WindowChrome.WindowChrome>

    <Border Background="{StaticResource BgBrush}" CornerRadius="10"
            BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- 커스텀 타이틀바 (OS 타이틀바 대체) -->
            <Grid Grid.Row="0" Height="40" Background="Transparent">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="14,0,0,0">
                    <TextBlock Text="📈" FontSize="15" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBlock Text="코인선물 상하방 전략 체크봇" Foreground="{StaticResource MutedBrush}"
                               FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    <TextBlock x:Name="VersionText" Text="" Foreground="{StaticResource AccentBrush}"
                               FontSize="11" FontWeight="Bold" VerticalAlignment="Center" Margin="8,0,0,0"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,4,6,0"
                            WindowChrome.IsHitTestVisibleInChrome="True">
                    <Button Content="&#xE921;" Style="{StaticResource CaptionButton}" Click="Min_Click" ToolTip="최소화"/>
                    <Button x:Name="MaxBtn" Content="&#xE922;" Style="{StaticResource CaptionButton}" Click="Max_Click" ToolTip="최대화"/>
                    <Button Content="&#xE8BB;" Style="{StaticResource CloseButton}" Click="Close_Click" ToolTip="닫기"/>
                </StackPanel>
            </Grid>

            <Grid Grid.Row="1" Margin="14,0,14,14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 상단: 심볼 입력 + 새로고침 + 자동갱신 -->
        <Grid Grid.Row="0" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock Text="코인선물 상하방 전략 체크봇" Foreground="{StaticResource AccentBrush}"
                       FontSize="20" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,20,0"/>

            <TextBlock Grid.Column="1" Text="심볼" Foreground="{StaticResource MutedBrush}"
                       VerticalAlignment="Center" Margin="0,0,8,0"/>
            <TextBox x:Name="SymbolBox" Grid.Column="2" Text="BTCUSDT" Width="140" Height="34"
                     VerticalContentAlignment="Center" Padding="8,0" FontSize="14" FontWeight="Bold"
                     Background="{StaticResource PanelBrush2}" Foreground="{StaticResource TextBrush}"
                     BorderBrush="{StaticResource BorderBrush}" CaretBrush="{StaticResource TextBrush}"
                     KeyDown="SymbolBox_KeyDown"/>

            <StackPanel Grid.Column="4" Orientation="Horizontal" VerticalAlignment="Center">
                <CheckBox x:Name="AutoRefresh" Content="자동갱신(15초)" Foreground="{StaticResource MutedBrush}"
                          VerticalAlignment="Center" Margin="0,0,12,0" Checked="AutoRefresh_Changed" Unchecked="AutoRefresh_Changed"/>
                <Button x:Name="ScannerBtn" Content="🔎 단타 스캐너" Click="Scanner_Click" Margin="0,0,8,0"
                        Foreground="{StaticResource TextBrush}" Background="{StaticResource PanelBrush2}"
                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Padding="14,7" Cursor="Hand" FontWeight="Bold"/>
                <Button x:Name="RefreshBtn" Content="새로고침" Style="{StaticResource PrimaryButton}" Click="Refresh_Click"/>
            </StackPanel>
        </Grid>

        <!-- 타임프레임 선택 -->
        <Border Grid.Row="1" Background="{StaticResource PanelBrush}" CornerRadius="8" Padding="10"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Margin="0,0,0,10">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="타임프레임" Foreground="{StaticResource MutedBrush}" VerticalAlignment="Center" Margin="2,0,12,0"/>
                <StackPanel x:Name="TfPanel" Orientation="Horizontal"/>
            </StackPanel>
        </Border>

        <!-- 본문: 좌(코인목록) / 중(차트) / 우(신호) -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="420"/>
            </Grid.ColumnDefinitions>

            <!-- 코인 목록 -->
            <Border Grid.Column="0" Background="{StaticResource PanelBrush}" CornerRadius="8"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Margin="0,0,10,0">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="코인 목록" Foreground="{StaticResource TextBrush}"
                               FontWeight="Bold" FontSize="14" Margin="0,0,0,8"/>
                    <TextBox x:Name="CoinFilterBox" Grid.Row="1" Height="30" VerticalContentAlignment="Center" Padding="8,0"
                             Margin="0,0,0,8" FontSize="12" Background="{StaticResource PanelBrush2}"
                             Foreground="{StaticResource TextBrush}" BorderBrush="{StaticResource BorderBrush}"
                             CaretBrush="{StaticResource TextBrush}" TextChanged="CoinFilterBox_TextChanged"
                             ToolTip="코인 검색 (예: BTC, SOL)"/>
                    <Grid Grid.Row="2">
                        <ListBox x:Name="CoinList" Background="Transparent" BorderThickness="0"
                                 Foreground="{StaticResource TextBrush}" ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                 SelectionChanged="CoinList_SelectionChanged">
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Padding" Value="8,6"/>
                                    <Setter Property="Margin" Value="0,1"/>
                                    <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ListBoxItem">
                                                <Border x:Name="bd" CornerRadius="5" Background="Transparent" Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsSelected" Value="True">
                                                        <Setter TargetName="bd" Property="Background" Value="{StaticResource PanelBrush2}"/>
                                                    </Trigger>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="bd" Property="Background" Value="#22FFFFFF"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ListBox.ItemContainerStyle>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid>
                                        <TextBlock Text="{Binding Symbol}" Foreground="{StaticResource TextBrush}"
                                                   FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding ChangeText}" Foreground="{Binding ChangeBrush}"
                                                   FontSize="11" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                        <TextBlock x:Name="CoinListHint" Text="불러오는 중..." Foreground="{StaticResource MutedBrush}"
                                   FontSize="12" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Grid>
                </Grid>
            </Border>

            <!-- 차트 영역 -->
            <Border Grid.Column="1" Background="{StaticResource PanelBrush}" CornerRadius="8"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Margin="0,0,10,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock x:Name="ChartTitle" Grid.Row="0" Text="차트" Foreground="{StaticResource TextBrush}"
                               FontWeight="Bold" FontSize="14" Margin="14,12,0,0"/>
                    <Canvas x:Name="ChartCanvas" Grid.Row="1" ClipToBounds="True" Cursor="SizeAll"
                            Background="Transparent" SizeChanged="ChartCanvas_SizeChanged" Margin="6"
                            MouseWheel="ChartCanvas_MouseWheel"
                            MouseLeftButtonDown="ChartCanvas_MouseDown"
                            MouseMove="ChartCanvas_MouseMove"
                            MouseLeftButtonUp="ChartCanvas_MouseUp"
                            ToolTip="드래그: 상하좌우 이동 · 휠: 확대/축소 · 더블클릭: 초기화"/>
                </Grid>
            </Border>

            <!-- 신호 패널 -->
            <Border Grid.Column="2" Background="{StaticResource PanelBrush}" CornerRadius="8"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                <Grid Margin="14">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- 종합 판정 배너 -->
                    <Border x:Name="VerdictBanner" Grid.Row="0" CornerRadius="8" Padding="16" Background="{StaticResource PanelBrush2}">
                        <StackPanel>
                            <TextBlock x:Name="VerdictText" Text="—" FontSize="30" FontWeight="Bold"
                                       Foreground="{StaticResource TextBrush}" HorizontalAlignment="Center"/>
                            <TextBlock x:Name="VerdictSub" Text="새로고침을 눌러 분석을 시작하세요" FontSize="13"
                                       Foreground="{StaticResource MutedBrush}" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                            <Border x:Name="ScalpBanner" CornerRadius="6" Padding="10,6" Margin="0,10,0,0" Background="#22000000">
                                <StackPanel>
                                    <TextBlock x:Name="ScalpVerdict" Text="단타 진입: —" FontSize="15" FontWeight="Bold"
                                               Foreground="{StaticResource TextBrush}" HorizontalAlignment="Center"/>
                                    <TextBlock x:Name="ScalpNote" Text="" FontSize="11" TextWrapping="Wrap"
                                               Foreground="{StaticResource MutedBrush}" HorizontalAlignment="Center"
                                               TextAlignment="Center" Margin="0,2,0,0"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- 상방/하방 게이지 -->
                    <Grid Grid.Row="1" Margin="0,12,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="하방" Foreground="{StaticResource BearBrush}" FontWeight="Bold" VerticalAlignment="Center"/>
                        <Border Grid.Column="1" Height="16" CornerRadius="8" Margin="8,0" Background="#33EF5350" ClipToBounds="True">
                            <Grid>
                                <Border x:Name="BullBar" HorizontalAlignment="Left" CornerRadius="8" Background="{StaticResource BullBrush}" Width="0"/>
                                <TextBlock x:Name="GaugeText" Text="" Foreground="{StaticResource TextBrush}"
                                           FontSize="11" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                        <TextBlock Grid.Column="2" Text="상방" Foreground="{StaticResource BullBrush}" FontWeight="Bold" VerticalAlignment="Center"/>
                    </Grid>

                    <!-- 요약 정보 -->
                    <UniformGrid Grid.Row="2" Columns="3" Margin="0,12,0,8">
                        <StackPanel>
                            <TextBlock Text="현재가" Foreground="{StaticResource MutedBrush}" FontSize="11"/>
                            <TextBlock x:Name="PriceText" Text="-" Foreground="{StaticResource TextBrush}" FontSize="15" FontWeight="Bold"/>
                        </StackPanel>
                        <StackPanel>
                            <TextBlock Text="추세강도(ADX)" Foreground="{StaticResource MutedBrush}" FontSize="11"/>
                            <TextBlock x:Name="AdxText" Text="-" Foreground="{StaticResource TextBrush}" FontSize="15" FontWeight="Bold"/>
                        </StackPanel>
                        <StackPanel>
                            <TextBlock Text="상방/하방 표" Foreground="{StaticResource MutedBrush}" FontSize="11"/>
                            <TextBlock x:Name="VoteText" Text="-" Foreground="{StaticResource TextBrush}" FontSize="15" FontWeight="Bold"/>
                        </StackPanel>
                    </UniformGrid>

                    <!-- 지표별 신호 리스트 -->
                    <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Auto" Margin="0,4,0,0">
                        <ItemsControl x:Name="SignalList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{StaticResource PanelBrush2}" CornerRadius="6" Padding="10,8" Margin="0,0,0,6">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="6"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <Border Grid.Column="0" Background="{Binding BarBrush}" CornerRadius="3" Margin="0,0,8,0"/>
                                            <StackPanel Grid.Column="1">
                                                <TextBlock Text="{Binding Name}" Foreground="{StaticResource TextBrush}" FontWeight="Bold" FontSize="13"/>
                                                <TextBlock Text="{Binding Comment}" Foreground="{StaticResource MutedBrush}" FontSize="11" TextWrapping="Wrap"/>
                                                <TextBlock Text="{Binding Value}" Foreground="{StaticResource MutedBrush}" FontSize="11"/>
                                            </StackPanel>
                                            <Border Grid.Column="2" Background="{Binding BarBrush}" CornerRadius="4" Padding="8,3" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding DirText}" Foreground="White" FontWeight="Bold" FontSize="12"/>
                                            </Border>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>

        <!-- 상태바 -->
        <Border Grid.Row="3" Background="{StaticResource PanelBrush}" CornerRadius="6" Padding="10,6" Margin="0,10,0,0"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
            <TextBlock x:Name="StatusText" Text="준비됨" Foreground="{StaticResource MutedBrush}" FontSize="12"/>
        </Border>
            </Grid>
        </Grid>
    </Border>
</Window>
