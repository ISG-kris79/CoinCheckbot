<Window x:Class="TradingCheckBot.ScannerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="단타 상승 시그널 스캐너" Height="860" Width="1080"
        MinHeight="640" MinWidth="900"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None" AllowsTransparency="True" ResizeMode="CanResize"
        Background="Transparent" Icon="app.ico"
        FontFamily="Segoe UI, Malgun Gothic">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="40" ResizeBorderThickness="6" GlassFrameThickness="0" CornerRadius="0"/>
    </WindowChrome.WindowChrome>

    <Border Background="{StaticResource BgBrush}" CornerRadius="10"
            BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- 커스텀 타이틀바 -->
            <Grid Grid.Row="0" Height="40" Background="Transparent">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="14,0,0,0">
                    <TextBlock Text="🔎" FontSize="14" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBlock Text="단타 상승 시그널 스캐너" Foreground="{StaticResource MutedBrush}"
                               FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,4,6,0"
                            WindowChrome.IsHitTestVisibleInChrome="True">
                    <Button Content="&#xE921;" Style="{StaticResource CaptionButton}" Click="Min_Click" ToolTip="최소화"/>
                    <Button x:Name="MaxBtn" Content="&#xE922;" Style="{StaticResource CaptionButton}" Click="Max_Click" ToolTip="최대화"/>
                    <Button Content="&#xE8BB;" Style="{StaticResource CloseButton}" Click="Close_Click" ToolTip="닫기"/>
                </StackPanel>
            </Grid>

            <Grid Grid.Row="1" Margin="14,0,14,14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 헤더 -->
        <Grid Grid.Row="0" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock Text="단타 상승 시그널 스캐너" Foreground="{StaticResource AccentBrush}"
                           FontSize="20" FontWeight="Bold"/>
                <TextBlock Text="선택한 코인을 진입/대기/회피로 판정 · 진입 트리거(눌림목·과매도반등·돌파재테스트·지지반등)가 떠야 진입 · 참고용(투자권유 아님)"
                           Foreground="{StaticResource MutedBrush}" FontSize="11" Margin="0,3,0,0"/>
            </StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                <CheckBox x:Name="AutoRefresh" Content="자동 스캔(30초)" Foreground="{StaticResource MutedBrush}"
                          VerticalAlignment="Center" Margin="0,0,12,0"
                          Checked="AutoRefresh_Changed" Unchecked="AutoRefresh_Changed"/>
                <Button x:Name="SearchBtn" Content="🔮 예상상승 서칭" Click="Search_Click" Margin="0,0,8,0"
                        Foreground="{StaticResource TextBrush}" Background="{StaticResource PanelBrush2}"
                        BorderBrush="{StaticResource AccentBrush}" BorderThickness="1" Padding="14,7" Cursor="Hand" FontWeight="Bold"/>
                <Button x:Name="ScanBtn" Content="선택 코인 스캔" Style="{StaticResource PrimaryButton}" Click="Scan_Click"/>
            </StackPanel>
        </Grid>

        <!-- 옵션 바 -->
        <Border Grid.Row="1" Background="{StaticResource PanelBrush}" CornerRadius="8" Padding="10"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Margin="0,0,0,10">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="타임프레임" Foreground="{StaticResource MutedBrush}" VerticalAlignment="Center" Margin="2,0,10,0"/>
                <StackPanel x:Name="TfPanel" Orientation="Horizontal" VerticalAlignment="Center"/>

                <TextBlock Text="표시" Foreground="{StaticResource MutedBrush}" VerticalAlignment="Center" Margin="24,0,8,0"/>
                <ComboBox x:Name="MinScoreBox" Width="120" Height="30" VerticalContentAlignment="Center"
                          SelectedIndex="1">
                    <ComboBoxItem Content="진입만"/>
                    <ComboBoxItem Content="진입+대기"/>
                    <ComboBoxItem Content="전체"/>
                </ComboBox>
            </StackPanel>
        </Border>

        <!-- 본문: 좌(코인 선택) / 우(결과) -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- 코인 선택 패널 -->
            <Border Grid.Column="0" Background="{StaticResource PanelBrush}" CornerRadius="8"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Margin="0,0,10,0">
                <Grid Margin="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="0,0,0,8">
                        <TextBlock Text="코인 선택" Foreground="{StaticResource TextBrush}" FontWeight="Bold" FontSize="14"/>
                        <TextBlock x:Name="SelCountText" Text="0개 선택" Foreground="{StaticResource AccentBrush}"
                                   FontSize="12" FontWeight="Bold" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                    </Grid>

                    <!-- 검색 -->
                    <TextBox x:Name="FilterBox" Grid.Row="1" Height="30" VerticalContentAlignment="Center" Padding="8,0"
                             Margin="0,0,0,8" FontSize="12" Background="{StaticResource PanelBrush2}"
                             Foreground="{StaticResource TextBrush}" BorderBrush="{StaticResource BorderBrush}"
                             CaretBrush="{StaticResource TextBrush}" TextChanged="FilterBox_TextChanged"
                             ToolTip="심볼 검색 (예: BTC, SOL)"/>

                    <!-- 선택 단축 버튼 -->
                    <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,8">
                        <Button Content="상위20" Click="SelectTop20_Click" Style="{StaticResource CaptionButton}"
                                Width="Auto" Padding="9,4" Foreground="{StaticResource TextBrush}"/>
                        <Button Content="전체선택" Click="SelectAll_Click" Style="{StaticResource CaptionButton}"
                                Width="Auto" Padding="9,4" Foreground="{StaticResource TextBrush}"/>
                        <Button Content="전체해제" Click="ClearSel_Click" Style="{StaticResource CaptionButton}"
                                Width="Auto" Padding="9,4" Foreground="{StaticResource TextBrush}"/>
                    </StackPanel>

                    <!-- 코인 체크리스트 -->
                    <Border Grid.Row="3" Background="{StaticResource PanelBrush2}" CornerRadius="6">
                        <Grid>
                            <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="2">
                                <ItemsControl x:Name="PickList">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border CornerRadius="4" Padding="8,5" Margin="2,1">
                                                <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                                          Foreground="{StaticResource TextBrush}" VerticalContentAlignment="Center">
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="{Binding Symbol}" Foreground="{StaticResource TextBrush}"
                                                                   FontSize="12" FontWeight="SemiBold" Width="120"/>
                                                        <TextBlock Text="{Binding ChangeText}" Foreground="{Binding ChangeBrush}" FontSize="11"/>
                                                    </StackPanel>
                                                </CheckBox>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                            <TextBlock x:Name="PickHint" Text="코인 목록 불러오는 중..." Foreground="{StaticResource MutedBrush}"
                                       FontSize="12" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Grid>
                    </Border>
                </Grid>
            </Border>

            <!-- 결과 영역 -->
            <Border Grid.Column="1" Background="{StaticResource PanelBrush}" CornerRadius="8"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- 컬럼 헤더 -->
                <Grid Grid.Row="0" Margin="14,12,14,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="42"/>
                        <ColumnDefinition Width="150"/>
                        <ColumnDefinition Width="170"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="순위" Foreground="{StaticResource MutedBrush}" FontSize="11"/>
                    <TextBlock Grid.Column="1" Text="심볼 / 판정" Foreground="{StaticResource MutedBrush}" FontSize="11"/>
                    <TextBlock Grid.Column="2" Text="진입 품질" Foreground="{StaticResource MutedBrush}" FontSize="11"/>
                    <TextBlock Grid.Column="3" Text="트리거 · 진입/목표/손절 · 근거" Foreground="{StaticResource MutedBrush}" FontSize="11"/>
                </Grid>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="8,0,8,8">
                    <ItemsControl x:Name="ResultList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{StaticResource PanelBrush2}" CornerRadius="8" Padding="12,10" Margin="6,4"
                                        BorderBrush="{Binding GradeBrush}" BorderThickness="1">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="42"/>
                                            <ColumnDefinition Width="150"/>
                                            <ColumnDefinition Width="170"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- 순위 -->
                                        <TextBlock Text="{Binding Rank}" Foreground="{StaticResource TextBrush}"
                                                   FontSize="20" FontWeight="Bold" VerticalAlignment="Center"/>

                                        <!-- 심볼 + 등급 + 24h -->
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Symbol}" Foreground="{StaticResource TextBrush}"
                                                       FontSize="16" FontWeight="Bold"/>
                                            <Border Background="{Binding GradeBrush}" CornerRadius="4" Padding="6,2"
                                                    HorizontalAlignment="Left" Margin="0,3,0,0">
                                                <TextBlock Text="{Binding Grade}" Foreground="White" FontSize="11" FontWeight="Bold"/>
                                            </Border>
                                            <TextBlock Text="{Binding ChangeText}" Foreground="{Binding ChangeBrush}"
                                                       FontSize="11" Margin="0,3,0,0"/>
                                        </StackPanel>

                                        <!-- 점수 게이지 -->
                                        <StackPanel Grid.Column="2" VerticalAlignment="Center" Margin="0,0,12,0">
                                            <TextBlock VerticalAlignment="Center">
                                                <Run Text="{Binding Score, Mode=OneWay}" FontSize="22" FontWeight="Bold"
                                                     Foreground="{Binding GradeBrush}"/><Run Text=" / 100" FontSize="11"
                                                     Foreground="{StaticResource MutedBrush}"/>
                                            </TextBlock>
                                            <Border Height="8" CornerRadius="4" Background="#33000000" Margin="0,5,0,0" ClipToBounds="True">
                                                <Border HorizontalAlignment="Left" CornerRadius="4"
                                                        Background="{Binding GradeBrush}" Width="{Binding BarWidth}"/>
                                            </Border>
                                            <TextBlock Text="{Binding RrText}" Foreground="{StaticResource MutedBrush}"
                                                       FontSize="11" Margin="0,4,0,0"/>
                                        </StackPanel>

                                        <!-- 진입/목표/손절 + 근거 칩 -->
                                        <StackPanel Grid.Column="3" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding LevelsText}" Foreground="{StaticResource TextBrush}"
                                                       FontSize="13" TextWrapping="Wrap"/>
                                            <ItemsControl ItemsSource="{Binding Reasons}" Margin="0,6,0,0">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <WrapPanel/>
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border Background="#2226A69A" CornerRadius="4" Padding="6,2" Margin="0,0,4,4"
                                                                BorderBrush="{StaticResource BullBrush}" BorderThickness="1">
                                                            <TextBlock Text="{Binding}" Foreground="{StaticResource BullBrush}" FontSize="11"/>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <!-- 빈 상태 안내 -->
                <TextBlock x:Name="EmptyHint" Grid.Row="1" Text="왼쪽에서 코인을 선택하고 ‘스캔 시작’을 누르세요"
                           Foreground="{StaticResource MutedBrush}" FontSize="14"
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Grid>
            </Border>
        </Grid>

        <!-- 상태바 -->
        <Border Grid.Row="3" Background="{StaticResource PanelBrush}" CornerRadius="6" Padding="10,6" Margin="0,10,0,0"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
            <TextBlock x:Name="StatusText" Text="준비됨" Foreground="{StaticResource MutedBrush}" FontSize="12"/>
        </Border>
            </Grid>
        </Grid>
    </Border>
</Window>
